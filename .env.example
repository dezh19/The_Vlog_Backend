# Server
HOST=0.0.0.0
PORT=1337

# Secrets (generate unique values for your environment)
APP_KEYS=replace-with-comma-separated-app-keys
API_TOKEN_SALT=replace-with-api-token-salt
ADMIN_JWT_SECRET=replace-with-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-with-transfer-token-salt
ENCRYPTION_KEY=replace-with-encryption-key
JWT_SECRET=replace-with-jwt-secret

# Database
DATABASE_CLIENT=sqlite
# Keep the SQLite database outside OneDrive so content persists reliably on Windows
DATABASE_FILENAME=C:/dev/strapi-data/data.db
DATABASE_CONNECTION_TIMEOUT=60000

# Optional admin bootstrap values for create-admin.js
STRAPI_ADMIN_EMAIL=admin@example.com
STRAPI_ADMIN_PASSWORD=change-me-now
STRAPI_ADMIN_FIRST_NAME=Admin
STRAPI_ADMIN_LAST_NAME=User
STRAPI_ADMIN_USERNAME=admin

# Optional GitHub rebuild dispatch settings
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_REPO_BRANCH=main
GITHUB_ACTIONS_EVENT_TYPE=strapi-content-updated
GITHUB_REBUILD_DEBOUNCE_MS=15000
GITHUB_ACTIONS_DISPATCH_TOKEN=
