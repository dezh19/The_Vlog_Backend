{
  "kind": "collectionType",
  "collectionName": "content_features",
  "info": {
    "singularName": "content-feature",
    "pluralName": "content-features",
    "displayName": "Content Feature",
    "description": "Content feature items (Videos, Blogs, Scriptures, Podcast, etc.)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "featureId": {
      "type": "string",
      "unique": true
    },
    "label": {
      "type": "string",
      "required": true
    },
    "headline": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "detail": {
      "type": "string"
    },
    "video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "videos"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "tag": {
      "type": "string"
    },
    "highlight": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
